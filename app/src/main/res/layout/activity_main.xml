<?xml version="1.0" encoding="utf-8"?>

<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp"
        android:layout_above="@id/bottomNavigationView">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MedBook"
            android:textSize="34sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Book appointments easily"
            android:textSize="16sp"
            android:textColor="#777777"
            android:layout_marginBottom="16dp" />

        <EditText
            android:id="@+id/searchDoctorsInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Search doctors..."
            android:padding="12dp"
            android:background="#FFFFFF"
            android:layout_marginBottom="16dp" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/allDoctorsBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="All" />

                <Button
                    android:id="@+id/cardiologistBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cardio"
                    android:layout_marginStart="8dp" />

                <Button
                    android:id="@+id/dentistBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Dentist"
                    android:layout_marginStart="8dp" />

                <Button
                    android:id="@+id/pediatricianBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pediatric"
                    android:layout_marginStart="8dp" />

                <Button
                    android:id="@+id/neurologistBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Neuro"
                    android:layout_marginStart="8dp" />

                <Button
                    android:id="@+id/dermatologistBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Dermatology"
                    android:layout_marginStart="8dp" />

                <Button
                    android:id="@+id/orthopedicBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Orthopedic"
                    android:layout_marginStart="8dp" />

                <Button
                    android:id="@+id/gynecologistBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Gynecology"
                    android:layout_marginStart="8dp" />

                <Button
                    android:id="@+id/psychiatristBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Psychiatry"
                    android:layout_marginStart="8dp" />

                <Button
                    android:id="@+id/ophthalmologistBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Eye"
                    android:layout_marginStart="8dp" />

                <Button
                    android:id="@+id/entBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ENT"
                    android:layout_marginStart="8dp" />

                <Button
                    android:id="@+id/radiologistBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Radiology"
                    android:layout_marginStart="8dp" />

                <Button
                    android:id="@+id/surgeonBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Surgery"
                    android:layout_marginStart="8dp" />

            </LinearLayout>

        </HorizontalScrollView>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerViewDoctors"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

    </LinearLayout>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigationView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="#FFFFFF"
        app:itemIconTint="@color/purple_500"
        app:itemTextColor="@color/purple_500"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/bottom_nav_menu" />

</RelativeLayout>